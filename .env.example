# Copy this file to .env and fill in your values.
# Docker Compose reads .env automatically for variable substitution.

POSTGRES_USER=auth
POSTGRES_PASSWORD=auth
POSTGRES_DB=auth

DATABASE_URL=postgres://auth:auth@db:5432/auth

JWT_SECRET=change-me-to-a-random-64-char-hex-string
PORT=50051

LOG_LEVEL=info